# =============================================================================
# Creative TV – Environment variables template
# Copy to .env.local and fill in values. On Vercel, set these in Project Settings.
# =============================================================================

# --- Core (required by config/index.ts) ---
NEXT_PUBLIC_ALCHEMY_API_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
LIVEPEER_API_KEY=

# --- Livepeer (server routes prefer LIVEPEER_FULL_API_KEY; view metrics fall back to LIVEPEER_API_KEY if unset) ---
# View counts: Studio key must have Viewers/Data API access. On Vercel production, set LIVEPEER_FULL_API_URL
# to https://livepeer.studio (or leave unset). Smoke test: GET /api/livepeer/views/<playbackId>
LIVEPEER_FULL_API_KEY=
LIVEPEER_FULL_API_URL=https://livepeer.studio
LIVEPEER_API_URL=https://livepeer.studio
LIVEPEER_WEBHOOK_ID=

# --- Alchemy ---
NEXT_PUBLIC_ALCHEMY_PAYMASTER_POLICY_ID=
NEXT_PUBLIC_ALCHEMY_RPC_URL=
NEXT_PUBLIC_BASE_RPC_URL=
# Lens Chain — Alchemy quickstart: https://www.alchemy.com/docs/reference/lens-api-quickstart
# Default (no NEXT_PUBLIC_LENS_ENV): Lens Sepolia testnet (37111, GRASS) via NEXT_PUBLIC_ALCHEMY_API_KEY
#   → https://lens-sepolia.g.alchemy.com/v2/<key>
# Production: NEXT_PUBLIC_LENS_ENV=production → mainnet (232, GHO); same key if Lens mainnet is on your Alchemy app
#   → https://lens-mainnet.g.alchemy.com/v2/<key> (else falls back to https://rpc.lens.xyz)
# Optional full URL override: NEXT_PUBLIC_LENS_RPC_URL=
NEXT_PUBLIC_LENS_ENV=
NEXT_PUBLIC_LENS_RPC_URL=
ALCHEMY_SWAP_PRIVATE_KEY=
NEXT_PUBLIC_ANYTOKEN_POLICY_ID=

# --- Goldsky (subgraphs) ---
GOLDSKY_PROJECT_ID=
GOLDSKY_API_KEY=
GOLDSKY_REALITY_ETH_PROJECT_ID=

# --- Reality.eth / Kleros (Base) ---
# Arbitrator proxy for new questions and evidence. Defaults to Kleros Oracle court if unset.
# Oracle: 0x05295972F75cFeE7fE66E6BDDC0435c9Fd083D18 | Precog: 0xd04f24364687dBD6db67D2101faE59e91a6e605B
# Any other Reality.eth-compatible proxy (product-specific deployments) — set the contract address here.
# NEXT_PUBLIC_REALITY_ETH_ARBITRATOR=

# --- Graph Studio (merged creative-platform subgraph) ---
# goldsky | studio | dual
SUBGRAPH_PROVIDER_MODE=goldsky
# Full query URL, e.g. https://gateway.thegraph.com/api/<query-key>/subgraphs/id/<deployment-id>
GRAPH_STUDIO_CREATIVE_PLATFORM_URL=
# Deploy key used by scripts/graph-studio/deploy-creative-platform.sh
GRAPH_STUDIO_DEPLOY_KEY=
# Optional: Studio subgraph slug if not exactly "creative-platform" (e.g. myteam/creative-platform)
# GRAPH_STUDIO_SUBGRAPH_SLUG=

# --- Supabase (optional for scripts) ---
SUPABASE_DB_PASSWORD=
DATABASE_URL=

# --- Story Protocol ---
NEXT_PUBLIC_STORY_NETWORK=testnet
# Alchemy supports Story mainnet RPC (story-mainnet.g.alchemy.com); set to use Alchemy for Story.
NEXT_PUBLIC_STORY_ALCHEMY_API_KEY=
# Alchemy Gas Manager policy for Story (mainnet 1514 / testnet 1315); when set, gas can be sponsored on Story.
NEXT_PUBLIC_STORY_POLICY_ID=
STORY_ALCHEMY_API_KEY=
STORY_RPC_URL=
STORY_PROTOCOL_PRIVATE_KEY=
FACTORY_OWNER_PRIVATE_KEY=
NEXT_STORYSCAN_API_KEY=
STORY_TEST_ACCOUNT=
FACTORY_ADDRESS=
DEPLOYER_PRIVATE_KEY=
FACTORY_OWNER=
DEFAULT_CONTRACT_URI=
DEFAULT_ROYALTY_RECIPIENT=
DEFAULT_ROYALTY_BPS=
DEFAULT_PLATFORM_FEE_RECIPIENT=
DEFAULT_PLATFORM_FEE_BPS=
TRUSTED_FORWARDERS=

# --- Coinbase CDP (onramp/offramp) ---
COINBASE_CDP_API_KEY_ID=
COINBASE_CDP_API_KEY_SECRET=

# --- POAP ---
POAP_API_KEY=
POAP_CLIENT_ID=
POAP_CLIENT_SECRET=

# --- Livepeer access control (signed playback) ---
ACCESS_CONTROL_PRIVATE_KEY=
NEXT_PUBLIC_ACCESS_CONTROL_PUBLIC_KEY=

# --- IPFS / storage ---
# Primary uploads use Lens Grove (@lens-chain/storage-client). Optional: Lighthouse if you still want a paid mirror.
NEXT_PUBLIC_LIGHTHOUSE_API_KEY=
NEXT_PUBLIC_IPFS_GATEWAY=https://w3s.link/ipfs
NEXT_PUBLIC_FILECOIN_FIRST_API_KEY=
NEXT_PUBLIC_ENABLE_FILECOIN_ARCHIVAL=
# Storacha/web3.storage backup removed from IPFSService (deprecated); keys unused.

# --- App URL (for server-side redirects / webhooks; Vercel sets VERCEL_URL) ---
NEXT_PUBLIC_APP_URL=

# --- Orb (@orbclub/modules) — parallel sovereign auth + media ---
# Defaults use orbapi.xyz QR + api.lens.xyz/graphql; override only if needed.
NEXT_PUBLIC_LENS_GRAPHQL_URL=
NEXT_PUBLIC_ORB_QR_INIT_URL=
NEXT_PUBLIC_ORB_QR_POLL_URL=
NEXT_PUBLIC_ORB_MEDIA_GATEWAY=
NEXT_PUBLIC_ORB_LENS_GATEWAY=
NEXT_PUBLIC_ORB_ARWEAVE_GATEWAY=
NEXT_PUBLIC_GROVE_API_URL=

# --- Optional / feature flags ---
NEXT_PUBLIC_STACK_API_KEY=
NEXT_PUBLIC_LENS_ENV=
NEXT_PUBLIC_REOWN_PROJECT_ID=
NEXT_PUBLIC_SNAPSHOT_API_KEY=
NEXT_PUBLIC_CERAMIC_NODE_URL=
NEXT_PUBLIC_ORBIS_NODE_URL=
NEXT_PUBLIC_ORBIS_ENVIRONMENT_ID=
NEXT_PUBLIC_ORBIS_ASSET_METADATA_MODEL_ID=
NEXT_PUBLIC_ORBIS_CRTV_CONTEXT_ID=
NEXT_PUBLIC_ORBIS_CRTV_VIDEOS_CONTEXT_ID=
NEXT_PUBLIC_ORBIS_METOKEN_MODEL_ID=
NEXT_PUBLIC_ORBIS_METOKEN_CONTEXT_ID=
NEXT_PUBLIC_GATEWAY_URL=
PINATA_JWT=
STREAM_KEY=

# --- Cron / internal API ---
CRON_SECRET=

# --- Scripts / Paragraph ---
PARAGRAPH_API_KEY=

# --- XMTP chat ---
# XMTP network: 'production' (default) | 'dev' | 'local'
# Must match XMTP_ENV used by scripts/xmtp-moderation-worker.ts
NEXT_PUBLIC_XMTP_ENV=production
# Bot inbox ID emitted by xmtp-moderation-worker on first boot
NEXT_PUBLIC_MODERATION_BOT_INBOX_ID=
